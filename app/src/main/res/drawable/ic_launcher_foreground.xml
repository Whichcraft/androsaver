<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroSaver icon: a TV/monitor displaying a night-sky landscape
    Canvas: 108×108dp — safe zone: 18–90
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Monitor frame drop shadow ─────────────────────────────── -->
    <path
        android:pathData="M22,20 L86,20 Q93,20 93,27 L93,78 Q93,85 86,85 L22,85 Q15,85 15,78 L15,27 Q15,20 22,20 Z"
        android:fillColor="#000000"
        android:fillAlpha="0.22"/>

