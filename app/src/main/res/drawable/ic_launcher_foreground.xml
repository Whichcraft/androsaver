        android:pathData="M20,24 L88,24 L88,77 L20,77 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="20" android:startY="24"
                android:endX="20"   android:endY="77"
                android:type="linear">
                <item android:offset="0"   android:color="#08103E"/>
                <item android:offset="0.6" android:color="#0C1F60"/>
                <item android:offset="1"   android:color="#061428"/>
            </gradient>
