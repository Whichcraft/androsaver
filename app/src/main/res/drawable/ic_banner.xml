<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroSaver TV banner: 320×180dp
    Left: TV/monitor with night-sky landscape
    Right: "AndroSaver" wordmark
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="320dp"
    android:height="180dp"
    android:viewportWidth="320"
    android:viewportHeight="180">

    <!-- ── Background gradient (deep space) ────────────────────────── -->
    <path android:pathData="M0,0 L320,0 L320,180 L0,180 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0" android:startY="0"
                android:endX="320" android:endY="180"
                android:type="linear">
                <item android:offset="0"   android:color="#1E0A4A"/>
                <item android:offset="0.5" android:color="#0E1858"/>
                <item android:offset="1"   android:color="#050E32"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ── Stars (scattered) ───────────────────────────────────────── -->
    <path android:pathData="M18,18 m-2,0 a2,2 0 1,0 4,0 a2,2 0 1,0 -4,0"
        android:fillColor="#FFFFFF" android:fillAlpha="0.90"/>
    <path android:pathData="M55,12 m-1.4,0 a1.4,1.4 0 1,0 2.8,0 a1.4,1.4 0 1,0 -2.8,0"
        android:fillColor="#FFFFFF" android:fillAlpha="0.75"/>
    <path android:pathData="M90,22 m-1,0 a1,1 0 1,0 2,0 a1,1 0 1,0 -2,0"
        android:fillColor="#FFFFFF" android:fillAlpha="0.60"/>
    <path android:pathData="M38,8 m-0.8,0 a0.8,0.8 0 1,0 1.6,0 a0.8,0.8 0 1,0 -1.6,0"
        android:fillColor="#FFFFFF" android:fillAlpha="0.55"/>
    <path android:pathData="M75,6 m-1.2,0 a1.2,1.2 0 1,0 2.4,0 a1.2,1.2 0 1,0 -2.4,0"
        android:fillColor="#FFFFFF" android:fillAlpha="0.80"/>
    <path android:pathData="M200,15 m-1.5,0 a1.5,1.5 0 1,0 3,0 a1.5,1.5 0 1,0 -3,0"
        android:fillColor="#FFFFFF" android:fillAlpha="0.70"/>
    <path android:pathData="M240,8 m-1,0 a1,1 0 1,0 2,0 a1,1 0 1,0 -2,0"
        android:fillColor="#FFFFFF" android:fillAlpha="0.60"/>
    <path android:pathData="M280,20 m-1.8,0 a1.8,1.8 0 1,0 3.6,0 a1.8,1.8 0 1,0 -3.6,0"
        android:fillColor="#FFFFFF" android:fillAlpha="0.85"/>
    <path android:pathData="M310,10 m-0.9,0 a0.9,0.9 0 1,0 1.8,0 a0.9,0.9 0 1,0 -1.8,0"
        android:fillColor="#FFFFFF" android:fillAlpha="0.55"/>
    <path android:pathData="M160,10 m-1,0 a1,1 0 1,0 2,0 a1,1 0 1,0 -2,0"
        android:fillColor="#FFFFFF" android:fillAlpha="0.65"/>

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!--  TV MONITOR ICON  (scaled ~1.5× from app icon, left side)    -->
    <!--  Original safe zone 18–90 in 108dp → mapped to 320×180 space -->
    <!--  Icon centred at (90, 90) in banner coords                   -->
    <!-- ══════════════════════════════════════════════════════════════ -->

    <!-- Monitor frame drop shadow -->
    <path
        android:pathData="M24,32 L156,32 Q168,32 168,44 L168,142 Q168,154 156,154 L24,154 Q12,154 12,142 L12,44 Q12,32 24,32 Z"
        android:fillColor="#000000"
        android:fillAlpha="0.22"/>

    <!-- Monitor frame body -->
    <path
        android:pathData="M22,30 L158,30 Q170,30 170,42 L170,140 Q170,152 158,152 L22,152 Q10,152 10,140 L10,42 Q10,30 22,30 Z"
        android:fillColor="#D8DEF2"/>

    <!-- Screen -->
    <path android:pathData="M22,42 L158,42 L158,140 L22,140 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="22" android:startY="42"
                android:endX="22"   android:endY="140"
                android:type="linear">
                <item android:offset="0"   android:color="#08103E"/>
                <item android:offset="0.6" android:color="#0C1F60"/>
                <item android:offset="1"   android:color="#061428"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Aurora band — purple -->
    <path
        android:pathData="M22,65 C40,56 62,80 90,65 C118,50 140,74 158,62
                          L158,76 C140,88 118,64 90,79 C62,94 40,70 22,82 Z"
        android:fillColor="#7C4DFF"
        android:fillAlpha="0.28"/>

    <!-- Aurora band — teal -->
    <path
        android:pathData="M22,75 C42,66 64,91 92,76 C120,61 142,86 158,74
                          L158,88 C142,100 120,75 92,90 C64,105 42,80 22,94 Z"
        android:fillColor="#1DE9B6"
        android:fillAlpha="0.35"/>

    <!-- Moon glow -->
    <path
        android:pathData="M126,52 m-22,0 a22,22 0 1,0 44,0 a22,22 0 1,0 -44,0"
        android:fillColor="#FFF9C4"
        android:fillAlpha="0.18"/>

    <!-- Moon -->
    <path
        android:pathData="M126,52 m-13,0 a13,13 0 1,0 26,0 a13,13 0 1,0 -26,0"
        android:fillColor="#FFE57F"/>

    <!-- Stars on screen -->
    <path android:pathData="M34,48 m-3.5,0 a3.5,3.5 0 1,0 7,0 a3.5,3.5 0 1,0 -7,0"
        android:fillColor="#FFFFFF" android:fillAlpha="0.95"/>
    <path android:pathData="M56,43 m-2.2,0 a2.2,2.2 0 1,0 4.4,0 a2.2,2.2 0 1,0 -4.4,0"
        android:fillColor="#FFFFFF" android:fillAlpha="0.80"/>
    <path android:pathData="M77,53 m-2.5,0 a2.5,2.5 0 1,0 5,0 a2.5,2.5 0 1,0 -5,0"
        android:fillColor="#FFFFFF" android:fillAlpha="0.88"/>
    <path android:pathData="M46,62 m-1.6,0 a1.6,1.6 0 1,0 3.2,0 a1.6,1.6 0 1,0 -3.2,0"
        android:fillColor="#FFFFFF" android:fillAlpha="0.65"/>
    <path android:pathData="M66,56 m-1.3,0 a1.3,1.3 0 1,0 2.6,0 a1.3,1.3 0 1,0 -2.6,0"
        android:fillColor="#FFFFFF" android:fillAlpha="0.55"/>

    <!-- Back mountain -->
    <path
        android:pathData="M22,140 L70,68 L118,140 Z"
        android:fillColor="#101F3A"/>

    <!-- Front mountain -->
    <path
        android:pathData="M88,140 L122,78 L158,140 Z"
        android:fillColor="#07101C"/>

    <!-- Horizon ground strip -->
    <path
        android:pathData="M22,130 L158,130 L158,140 L22,140 Z"
        android:fillColor="#05100A"/>

    <!-- Stand neck -->
    <path
        android:pathData="M87,152 L93,152 L93,164 L87,164 Z"
        android:fillColor="#B0BEC5"/>

    <!-- Stand base -->
    <path
        android:pathData="M64,164 L116,164 Q119,164 119,167 L119,170 Q119,173 116,173 L64,173 Q61,173 61,170 L61,167 Q61,164 64,164 Z"
        android:fillColor="#90A4AE"/>

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!--  WORDMARK: "AndroSaver"  (right half of banner)              -->
    <!--  Hand-traced letter paths, baseline y≈108, cap-height≈36     -->
    <!-- ══════════════════════════════════════════════════════════════ -->

    <!-- A -->
    <path android:pathData="M192,120 L200,84 L208,120 M194.5,108 L205.5,108"
        android:strokeColor="#FFFFFF" android:strokeWidth="4"
        android:fillColor="#00000000"/>
    <!-- n -->
    <path android:pathData="M212,120 L212,98 Q212,94 216,94 Q220,94 220,98 L220,120"
        android:strokeColor="#FFFFFF" android:strokeWidth="4"
        android:fillColor="#00000000"/>
    <!-- d -->
    <path android:pathData="M232,84 L232,120 M232,120 Q232,94 228,94 Q224,94 224,107 Q224,120 228,120 L232,120"
        android:strokeColor="#FFFFFF" android:strokeWidth="4"
        android:fillColor="#00000000"/>
    <!-- r -->
    <path android:pathData="M236,120 L236,94 M236,100 Q238,94 244,94"
        android:strokeColor="#FFFFFF" android:strokeWidth="4"
        android:fillColor="#00000000"/>
    <!-- o -->
    <path android:pathData="M254,107 m-8,0 a8,13 0 1,0 16,0 a8,13 0 1,0 -16,0"
        android:strokeColor="#FFFFFF" android:strokeWidth="4"
        android:fillColor="#00000000"/>

    <!-- S -->
    <path android:pathData="M278,97 Q278,94 274,94 Q268,94 268,101 Q268,107 278,107 Q284,107 284,114 Q284,120 278,120 Q272,120 270,117"
        android:strokeColor="#D4AAFF" android:strokeWidth="4"
        android:fillColor="#00000000"/>
    <!-- a -->
    <path android:pathData="M298,120 L298,98 Q294,94 290,94 Q286,94 286,107 Q286,120 290,120 Q294,120 298,120"
        android:strokeColor="#D4AAFF" android:strokeWidth="4"
        android:fillColor="#00000000"/>
    <!-- v -->
    <path android:pathData="M302,94 L308,120 L314,94"
        android:strokeColor="#D4AAFF" android:strokeWidth="4"
        android:fillColor="#00000000"/>

</vector>
