<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:maxWidth="600dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dropbox_setup_title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dropbox_setup_instructions"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dropbox_app_key_label"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/appKeyEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:hint="@string/dropbox_app_key_hint"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dropbox_app_secret_label"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/appSecretEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:hint="@string/dropbox_app_secret_hint"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dropbox_folder_label"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/folderEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:hint="@string/dropbox_folder_hint"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/authStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/authorizeButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dropbox_authorize"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/revokeButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/revoke_authorization"
            android:enabled="false" />

    </LinearLayout>
</ScrollView>
